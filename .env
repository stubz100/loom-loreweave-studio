# Loreweave Studio — central config (COMMITTED; non-secret settings only).
# The orchestrator (Python) and the Vite UI both read this file.
# Precedence: real environment variable > .env.local > .env > built-in default.
#
# Secrets (the orchestrator token) live in .env.local (gitignored). Copy the keys
# from the block at the bottom into your own .env.local for dev.

# --- Orchestrator (R101 transport) ---
LOOM_ORCH_HOST=127.0.0.1
LOOM_ORCH_PORT=8765

# --- UI (Vite reads VITE_* automatically) ---
VITE_LOOM_ORCH_URL=http://127.0.0.1:8765

# --- CORS: allowed browser origins for the loopback API (review #1) ---
LOOM_CORS_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://tauri.localhost,https://tauri.localhost

# --- Logging (brief | verbose, or a standard level name: debug/info/warning/error) ---
#   brief   = lifecycle milestones + warnings/errors (default)
#   verbose = + per-tick detail (disk refreshes, dispatch) for diagnosing deliveries
# Backend logs -> stderr + .loom_state/logs/orchestrator.log (rotating, gitignored).
# Frontend logs -> browser/webview console (VITE_* is read by the UI).
LOOM_LOG_LEVEL=brief
VITE_LOOM_LOG_LEVEL=brief

# --- Model weights cache (HF) — a SHARED dir on the work disk, off the system drive ---
# loom points HF_HOME here at startup, so weights (the hub/ cache) land next to projects
# instead of the buried ~/.cache/huggingface. Weights are shared across ALL projects
# (never per-project, never in git, R160) — one ~330 GB casting set, not a copy each.
# Default: <work-disk drive>\loom-models (e.g. F:\loom-models). Override the path here.
LOOM_MODELS_DIR=F:\loom-models

# --- Launch gate: which phases are runnable NOW and hard-required at startup (M7, §11) ---
# P0 = foundation spine; P1 = L1/L2 record layer (StoryBible style + AssetProfile/version).
# Both ship in the app, so both gate. A broken P1 schema now refuses to start (not just
# reported). P1 declares no model weight yet, so /generate stays ungated until M2's `multi`.
LOOM_ACTIVE_PHASES=P0,P1

# --- Secrets go in .env.local (gitignored), NOT here. Template: ---
#   LOOM_ORCH_TOKEN=dev-xxxxxxxx          # orchestrator enforces this on /generate
#   VITE_LOOM_ORCH_TOKEN=dev-xxxxxxxx     # dev UI sends it as the X-Loom-Token header
# In the packaged Tauri app the token is generated at runtime and injected into the
# webview — no .env.local needed there.
