{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loom:job.schema.json",
  "title": "Queue job record (P0)",
  "type": "object",
  "required": ["schema_version", "id", "pipeline", "mode", "params", "requester_id", "status", "created_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^job_[0-9a-f]{8}$" },
    "pipeline": { "type": "string" },
    "mode": { "type": "string" },
    "params": { "type": "object" },
    "requester_id": { "type": "string" },
    "vram_estimate_gb": { "type": "number" },
    "resumable": { "type": "boolean" },
    "retry_count": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["queued", "running", "done", "failed", "canceled"] },
    "progress": { "type": "number" },
    "note": { "type": "string" },
    "created_at": { "type": "string" },
    "started_at": { "type": ["string", "null"] },
    "finished_at": { "type": ["string", "null"] },
    "wall_s": { "type": ["number", "null"] },
    "result": { "type": ["object", "null"] },
    "log_tail": { "type": "string" },
    "batch_id": { "type": "string" },
    "index": { "type": "integer" },
    "batch_size": { "type": "integer" }
  }
}
