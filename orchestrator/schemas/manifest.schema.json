{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loom:manifest.schema.json",
  "title": "Normalized completion envelope (CompletionRecord, P0 §8)",
  "type": "object",
  "required": ["ok", "returncode", "outputs"],
  "properties": {
    "ok": { "type": "boolean" },
    "returncode": { "type": "integer" },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "manifest_path": { "type": ["string", "null"] },
    "manifest_status": { "type": ["string", "null"] },
    "duration_s": { "type": ["number", "null"] },
    "peak_vram_gb": { "type": ["number", "null"] },
    "stderr_tail": { "type": ["string", "null"] },
    "error": { "type": ["string", "null"] }
  }
}
