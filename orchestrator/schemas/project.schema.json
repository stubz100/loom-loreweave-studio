{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loom:project.schema.json",
  "title": "Loreweave project (StoryBible root, P0)",
  "type": "object",
  "required": ["schema_version", "id", "name", "created_at", "workspace_path", "format", "size_cap_gb"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^prj_[0-9a-f]{6}$" },
    "name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "workspace_path": { "type": "string" },
    "format": {
      "type": "object",
      "required": ["aspect", "resolution", "fps", "audio_master"],
      "properties": {
        "aspect": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
        "resolution": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
        "fps": { "type": "integer", "minimum": 1 },
        "audio_master": {
          "type": "object",
          "required": ["container", "rate_hz", "bits", "channels"],
          "properties": {
            "container": { "type": "string" },
            "rate_hz": { "type": "integer" },
            "bits": { "type": "integer" },
            "channels": { "type": "integer" }
          }
        }
      }
    },
    "size_cap_gb": { "type": "number", "minimum": 50 }
  }
}
