{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loom:version.schema.json",
  "title": "ProfileVersion (P1 §3.4 — three-state lifecycle; M1 = Saved, not Finalized)",
  "type": "object",
  "required": ["schema_version", "id", "name", "finalized", "saved_at", "prompt_template", "ref_set", "casting"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^ver_[0-9a-f]{6}$" },
    "name": { "type": "string", "minLength": 1 },
    "derived_from": { "type": ["string", "null"] },
    "finalized": { "type": "boolean" },
    "saved_at": { "type": "string" },
    "prompt_template": { "type": "string" },
    "anchor_ref": { "type": ["string", "null"] },
    "anchor": {
      "type": ["object", "null"],
      "description": "M4 face anchor (R94): the chosen detailed-face image, copied into the version's faces/ dir (self-contained, survives job deletion). Per-version and re-pickable (scar/tattoo). Feeds the Stage-B identity-lock pass (R93: on by default once present, opt-out).",
      "required": ["file", "set_at"],
      "properties": {
        "file": { "type": "string" },
        "source_output": { "type": "string" },
        "job_id": { "type": "string" },
        "set_at": { "type": "string" }
      }
    },
    "ref_set": {
      "type": "array",
      "description": "Stage-C curated refs (the future LoRA corpus). Each item carries its frozen coverage_cell (P1→P2 contract, P1-16) so P2's template captioner can caption it. Promoted string→object in P1/M3 (mirrors casting[]); legacy empty ref_sets are unaffected.",
      "items": {
        "type": "object",
        "required": ["id", "file", "coverage_cell"],
        "properties": {
          "id": { "type": "string", "pattern": "^ref_[0-9a-f]{6}$" },
          "file": { "type": "string" },
          "coverage_cell": {
            "type": "object",
            "required": ["shot_size", "angle", "expression", "background"],
            "additionalProperties": false,
            "properties": {
              "shot_size": { "type": "string", "enum": ["face_closeup", "portrait", "waist_up", "full_body"] },
              "angle": { "type": "string", "enum": ["front", "three_quarter_left", "three_quarter_right", "profile_left", "profile_right", "back"] },
              "expression": { "type": "string", "enum": ["neutral", "smile", "serious", "sad", "surprised"] },
              "background": { "type": "string" }
            }
          },
          "source_output": { "type": "string" },
          "job_id": { "type": "string" },
          "pipeline": { "type": ["string", "null"] },
          "method": { "type": ["string", "null"] },
          "seed": { "type": ["integer", "null"] },
          "added_at": { "type": "string" }
        }
      }
    },
    "casting": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "job_id", "file", "starred"],
        "properties": {
          "id": { "type": "string", "pattern": "^cand_[0-9a-f]{6}$" },
          "job_id": { "type": "string" },
          "file": { "type": "string" },
          "source_output": { "type": "string" },
          "pipeline": { "type": ["string", "null"] },
          "seed": { "type": ["integer", "null"] },
          "starred": { "type": "boolean" },
          "added_at": { "type": "string" }
        }
      }
    }
  }
}
